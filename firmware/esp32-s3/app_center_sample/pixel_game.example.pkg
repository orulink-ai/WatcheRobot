{
  "manifestVersion": 1,
  "id": "pixel-game",
  "name": "Pixel Game",
  "version": "game-v1",
  "description": "A tiny downloaded app-pack demo",
  "state": "standby",
  "anim": "standby",
  "permissions": ["display"],
