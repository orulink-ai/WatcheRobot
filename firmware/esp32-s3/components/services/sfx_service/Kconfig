menu "Watcher SFX Service"

    config WATCHER_SFX_TASK_STACK_SIZE
        int "SFX task stack size"
        default 6144
        range 3072 8192
        help
            Stack size for the local sound-effect playback task. The playback
            chunk defaults to 2KB; 6KB keeps headroom for SD/SPIFFS fallback,
            audio HAL transitions, and diagnostic snapshots.

    config WATCHER_SFX_STREAM_CHUNK_SIZE
        int "SFX stream chunk size"
        default 2048
        range 1024 4096
        help
            Bytes written to the audio HAL per local SFX streaming chunk.
            Lower values reduce task stack pressure with a small I/O overhead.

endmenu
